<?xml version='1.0' encoding='utf-8'?>
<widget id="com.github.topcoder520" 
    version="1.0.0" 
    xmlns="http://www.w3.org/ns/widgets" 
    xmlns:cdv="http://cordova.apache.org/ns/1.0"
    xmlns:android="http://android.com"
    >
    <name>Note笔记</name>
    <description>基于cordova实现的一个简单笔记app。</description>
    <author email="dream4haji@gmail.com" href="https://github.com/topcoder520">
        huangjing，一个对技术感兴趣的程序员!
    </author>
    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <access origin="*" />
    <platform name="android">
        <edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
            <application android:networkSecurityConfig="@xml/network_security_config" />
        </edit-config>

        <!-- 复制配置文件到指定目录 -->
        <resource-file src="res/android/xml/network_security_config.xml" target="app/src/main/res/xml/network_security_config.xml" />

        <preference name="AndroidInsecureFileModeEnabled" value="true" />
        <preference name="AndroidPersistentFileLocation" value="Compatibility" />
        <preference name="iosExtraFilesystems" value="library,library-nosync,documents,documents-nosync,cache,bundle,root" />
        <preference name="AndroidExtraFilesystems" value="files,files-external,documents,sdcard,cache,cache-external,assets,root" />

        <preference name="allowFileAccessFromFileURLs" value="true" />
        <preference name="allowUniversalAccessFromFileURLs" value="true" />

        <config-file parent="/*" platform="android" target="AndroidManifest.xml" xmlns:android="http://schemas.android.com/apk/res/android">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
            <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
            <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
        </config-file>
        <!--hooks -->
        <hook type="after_build" src="scripts/android/hook_after_build.js" />
        <!-- 启动屏 Android 12版本以前可用 -->
        <!-- <splash src="res/screen/android/launch_v10.png" density="land-hdpi"/>    
        <splash src="res/screen/android/launch_v10.png" density="land-ldpi"/>    
        <splash src="res/screen/android/launch_v10.png" density="land-mdpi"/>    
        <splash src="res/screen/android/launch_v10.png" density="land-xhdpi"/>   
        <splash src="res/screen/android/launch_v10.png" density="port-hdpi"/>  
        <splash src="res/screen/android/launch_v10.png" density="port-ldpi"/>  
        <splash src="res/screen/android/launch_v10.png" density="port-mdpi"/>  
        <splash src="res/screen/android/launch_v10.png" density="port-xhdpi"/> -->
        <!-- 启动屏 Android 12版本以后可用 -->
        <!-- 核心：设置启动页图标路径 -->
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="res/screen/android/launch.png" />
        <!--启动屏 配置-->
        <preference name="AutoHideSplashScreen" value="false" />
        <preference name="SplashScreenDelay" value="10000" /> <!-- defaults to "3000" -->
        <preference name="SplashScreenBackgroundColor" value="#ffffff" /> <!-- defaults to "#464646" -->

        <!--app logo icon-->  
        <icon density="ldpi" src="res/icon/android/icon-36-ldpi.png" />
        <icon density="ldpi-v26" src="res/icon/android/icon-36-ldpi.png" />
        <icon density="mdpi" src="res/icon/android/icon-48-mdpi.png" />
        <icon density="mdpi-v26" src="res/icon/android/icon-48-mdpi.png" />
        <icon density="hdpi" src="res/icon/android/icon-72-hdpi.png" />
        <icon density="hdpi-v26" src="res/icon/android/icon-72-hdpi.png" />
        <icon density="xhdpi" src="res/icon/android/icon-96-xhdpi.png" />
        <icon density="xhdpi-v26" src="res/icon/android/icon-96-xhdpi.png" />
        <icon density="xxhdpi" src="res/icon/android/icon-144-xxhdpi.png" />
        <icon density="xxxhdpi" src="res/icon/android/icon-192-xxxhdpi.png" />
    </platform>
</widget>
